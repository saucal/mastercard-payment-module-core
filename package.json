{
	"name": "mpgs-core",
	"version": "1.0.0",
	"description": "MPGS Core",
	"assets": {
		"js": {
			"src": "src/js/",
			"out": "assets/js/"
		},
		"css": {
			"src": "src/sass/",
			"out": "assets/css/"
		}
	},
	"scripts": {
		"watch": "webpack --mode=none --watch",
		"build:assets": "webpack --mode=none",
		"build:deps": "rm -rf vendor && composer install --no-dev --optimize-autoloader",
		"build": "npm run build:assets && npm run build:deps",
		"format:js": "wp-scripts format ./src",
		"lint:css": "wp-scripts lint-style ./src",
		"lint:css:fix": "wp-scripts lint-style ./src --fix",
		"lint:js": "wp-scripts lint-js ./src",
		"lint:js:fix": "wp-scripts lint-js ./src --fix",
		"lint:php": "composer run-script phpcs ./",
		"test:js": "wp-scripts test-unit-js --coverage",
		"test:js:watch": "npm run test:js -- --watch",
		"test:php": "npm run test:php-prepare -- wordpress_test root root localhost && npm run test:php-run",
		"test:php-prepare": "./bin/install-wp-tests.sh",
		"test:php-run": "composer test-unit",
		"prearchive": "cross-var rm -rf $npm_package_config_wp_org_slug.zip vendor/ node_modules/ && composer install --no-dev --optimize-autoloader && npm install --only=prod --ignore-scripts"
	},
	"keywords": [
		"mpgs core"
	],
	"eslintConfig": {
		"extends": [
			"plugin:@woocommerce/eslint-plugin/recommended"
		]
	},
	"stylelint": {
		"extends": [
			"@wordpress/stylelint-config/scss"
		],
		"rules": {
			"no-descending-specificity": null,
			"selector-class-pattern": null,
			"unit-allowed-list": [
				"em",
				"px",
				"%",
				"s",
				"rem",
				"vw",
				"vh",
				"ms",
				"fr"
			]
		}
	},
	"browserslist": [
		"> 1%",
		"not dead"
	],
	"author": "SAU/CAL",
	"license": "GPL-2.0+",
	"devDependencies": {
		"@babel/cli": "^7.25.9",
		"@babel/core": "^7.26.0",
		"@babel/preset-env": "^7.26.0",
		"@babel/register": "^7.25.9",
		"@woocommerce/eslint-plugin": "^2.3.0",
		"@wordpress/blocks": "^14.0.0",
		"@wordpress/scripts": "^30.4.0",
		"babel-loader": "^9.2.1",
		"css-loader": "^7.1.2",
		"glob": "^11.0.0",
		"jest": "^29.7.0",
		"mini-css-extract-plugin": "^2.9.2",
		"css-minimizer-webpack-plugin": "^7.0.0",
		"sass": "^1.80.6",
		"sass-loader": "^16.0.3",
		"style-loader": "^4.0.0",
		"stylelint": "^14.16.1",
		"webpack": "^5.70.0",
		"webpack-cli": "^5.1.4",
		"webpack-remove-empty-scripts": "^1.0.4"
	},
	"engines": {
		"node": ">=18.0.0",
		"npm": ">=7"
	},
	"config": {
		"wp_org_slug": "mpgs-core",
		"version_replace_paths": [
			"includes",
			"mpgs-core.php",
			"uninstall.php"
		]
	}
}
